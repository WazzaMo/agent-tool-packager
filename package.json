{
  "name": "@wazzamo-agent-tools/packager",
  "version": "0.2.2",
  "description": "CLI for agentic software development workflows",
  "type": "module",
  "main": "dist/atp.js",
  "bin": {
    "atp": "bin/atp"
  },
  "homepage": "https://github.com/WazzaMo/agent-tool-packager",
  "scripts": {
    "build": "node scripts/sync-version.js && vite build",
    "sync-version": "node scripts/sync-version.js",
    "install-home": "node scripts/install-to-home.js",
    "uninstall-home": "node scripts/uninstall-from-home.js",
    "dev": "tsx src/atp.ts",
    "start": "node dist/atp.js",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "agentic",
    "mcp",
    "catalog"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=24.14.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vitest": "^4.0.18"
  }
}
