{
  "name": "atp",
  "version": "0.1.0",
  "description": "CLI for agentic software development workflows",
  "type": "module",
  "main": "dist/atp.js",
  "bin": {
    "atp": "dist/atp.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "tsx src/atp.ts",
    "start": "node dist/atp.js",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cli",
    "agentic",
    "mcp",
    "catalog"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "engines": {
    "node": ">=24.14.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "npm:rolldown-vite@^7.3.1",
    "vitest": "^4.0.18"
  }
}
